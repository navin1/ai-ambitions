# ── BigQuery ──────────────────────────────────────────────────────────────────
BIGQUERY_PROJECT_ID=your-gcp-project
BIGQUERY_DATASET=ai_ambitions
BQ_JOB_PROJECT_ID=your-gcp-project   # project billed for BQ query jobs

# ── Vertex AI / Gemini — only required when AI features are enabled ────────────
VERTEX_AI_PROJECT=your-gcp-project
VERTEX_AI_LOCATION=us-central1
GEMINI_MODEL=gemini-2.5-flash

# ── Local dev credentials ─────────────────────────────────────────────────────
# Option A (recommended): gcloud auth application-default login
#   No env vars needed — ADC resolves automatically.
#
# Option B: explicit service-account key file (not recommended for dev)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── ForgeRock Identity Gateway ────────────────────────────────────────────────
# Production only — the IG sidecar runs in GKE and reads these from the
# ai-ambitions-config ConfigMap. In local dev the IG is not present; the app
# falls back to dev@local when the headers are absent.
#
# The app itself only reads FORGEROCK_EMAIL_HEADER / FORGEROCK_USERNAME_HEADER /
# FORGEROCK_GROUPS_HEADER to know which headers IG will inject. The AM_* vars
# are consumed by IG (and by the app's own AM REST calls — see auth.py).
FORGEROCK_AM_URL=https://am.example.com/am
FORGEROCK_AM_REALM=/
FORGEROCK_AM_COOKIE_NAME=iPlanetDirectoryPro
FORGEROCK_EMAIL_HEADER=x-fr-email
FORGEROCK_USERNAME_HEADER=x-fr-username
FORGEROCK_GROUPS_HEADER=x-fr-groups

# ── AD-group-based roles ───────────────────────────────────────────────────────
# FORGEROCK_AM_GROUPS_ATTRIBUTE is the AM session property holding AD group
# membership. FORGEROCK_ADMIN_GROUP is the AD group name that grants the
# "admin" role — leave empty until that group exists; everyone resolves to
# the "user" role until then. FORGEROCK_ACCESS_GROUP, if set, is required just
# to reach the app at all (admins always pass); leave empty to keep today's
# behavior of "any authenticated user can view".
FORGEROCK_AM_GROUPS_ATTRIBUTE=memberOf
FORGEROCK_ADMIN_GROUP=
FORGEROCK_ACCESS_GROUP=

# ── Admin file upload (GCS) ────────────────────────────────────────────────────
# Bucket the /api/admin/upload endpoint (admin role only) writes to.
# Layout under the prefix: {prefix}/input/ (landing), {prefix}/archive/success/,
# {prefix}/archive/failure/ (+ a matching .errors.json per failed file).
GCS_PROJECT_ID=your-gcp-project      # defaults to BIGQUERY_PROJECT_ID if unset
GCS_UPLOAD_BUCKET=your-upload-bucket
GCS_UPLOAD_PREFIX=ai_ambitions

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
